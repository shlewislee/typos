# Serial printer device path
TYPOS_DEVICE=/dev/ttyACM0

# Serial baud rate (default: 9600)
TYPOS_BAUDRATE=9600

# Printer paper width in mm
TYPOS_WIDTH=72

# Printer DPI
# TYPOS_DPI=

# Path to templates TOML config
# TYPOS_TEMPLATES=/app/templates/templates.toml

# Server listen address (default: :8888)
TYPOS_ADDR=:8888

# Custom font search path
# TYPOS_FONT_PATH=/app/fonts

# Image gamma correction (default: 1.95)
# TYPOS_GAMMA=1.95

# Dither algorithm: 0=Atkinson, 1=FloydSteinberg, 2=StevenPigeon (default: 0)
# TYPOS_DITHER_METHOD=0

# Max retained job history (default: 1000)
# TYPOS_MAX_JOBS=1000

# Enable debug logging (true/false)
# TYPOS_VERBOSE=true
